ENVIRONMENT=development
VERSION=0.1.0

DATABASE_URL=sqlite+aiosqlite:///./data/localhub.db
DATABASE_ECHO=false

PUBLIC_FRONTEND_ORIGIN=https://saffybuffy.netlify.app
FRONTEND_ORIGINS=http://localhost:5173
CORS_ALLOW_CREDENTIALS=false

ENABLE_OPENAPI=true
ENABLE_SWAGGER_UI=true
ENABLE_REDOC=false

LOG_LEVEL=INFO
LOG_DIR=./logs

OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
TAVILY_API_KEY=
FAISS_INDEX_DIR=./data/faiss
VECTOR_MCP_URL=
VECTOR_MCP_API_KEY=
VECTOR_MCP_TIMEOUT_SECONDS=5
VECTOR_MCP_HOST=127.0.0.1
VECTOR_MCP_PORT=8001
VECTOR_MCP_PUBLIC_HOST=
VECTOR_SOURCE_URL=
VECTOR_SOURCE_API_KEY=
VECTOR_SOURCE_TIMEOUT_SECONDS=30
VECTOR_SOURCE_CACHE_SECONDS=300
MEDIA_DIR=./data/media
TOURISM_DATA_DIR=C:/Users/SSAFY/Desktop/data2/부산
DATA_IMPORT_API_KEY=replace-with-a-long-random-secret
AGENT_RECURSION_LIMIT=8

LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=localhub-rag-agent
